---
// @ts-nocheck
import MainLayout from "../layouts/MainLayout.astro"
import Cast from "../components/Cast.astro"

// mood ophalen die ik met de url heb mee gegeven
export const prerender = false;
const mood = Astro.url.searchParams.get("mood")
console.log("mood in results:", mood)

const moodNaarGenre = {
	happy: 35,       // Comedy
	sad: 18,         // Drama
	romantic: 10749, // Romance
	energetic: 28,   // Action
	stressed: 16     // Animation
}

const genreId = moodNaarGenre[mood]

const base = "https://api.themoviedb.org/3"
const endpoint = "/discover/movie?with_genres=" + genreId + "&sort_by=popularity.desc&vote_average.gte=6"
const API_KEY = import.meta.env.TMDB_API_KEY
const url = base + endpoint + "&api_key=" + API_KEY

console.log("URL:", url);
// fetch naar de movies
const response = await fetch(url)
const data = await response.json()
// console.log(data.results[0])

// om de posters van tmdm op te halen aan de hand van een random getaal
// bron image oproepen: https://developer.themoviedb.org/docs/image-basics
// bron math.random: https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Math/random
// bron math.floor: https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Math/floor
const randomIndex = Math.floor(Math.random() * data.results.length)
const randomMovie = data.results[randomIndex]
const posterPath = randomMovie.poster_path
const posterUrl = "https://image.tmdb.org/t/p/w500" + posterPath

const backDrop = randomMovie.backdrop_path
const backDropUrl = "https://image.tmdb.org/t/p/original" + backDrop

// film informatie ophalen van de random film
const filmBeschrijving = randomMovie.overview
const filmTitel = randomMovie.title


// fetch naar de cast 
const endPointCast = "/movie/" + randomMovie.id + "/credits?" 
const urlCast = base + endPointCast + "&api_key=" + API_KEY
console.log(urlCast)
const responseCast = await fetch(urlCast)
const dataCast = await responseCast.json()

const customAnim = {
  old: {
    name: "bump",
    duration: "0.5s",
    easing: "ease-in",
    direction: "reverse",
  },
  new: {
    name: "bump",
    duration: "0.5s",
    easing: "ease-in",
  },
};

const customAnimBackwards = {
  old: {
    name: "bumpBackwards",
    duration: "0.5s",
    easing: "ease-in",
    direction: "reverse",
  },
  new: {
    name: "bumpBackwards",
    duration: "0.5s",
    easing: "ease-in",
  },
};

const customTransition = {
  forwards: customAnim,
  backwards: customAnimBackwards,
};

// console.log("API data:", data);
// console.log("Films:", data.results);


// testeb of ik de data van de genres kan ophalen van de API zodat ik die kan koppelen aan de moodNaarGenre object in de mood.astro
// const url = base + endpoint + "?api_key=" + API_KEY
// const response = await fetch(url)
// const data = await response.json()
// console.log(data)

// testen of ik de juiste genreId krijg bij een mood
// const geselecteerdeMood = "happy"
// const genreId = moodNaarGenre[geselecteerdeMood]
// console.log(genreId)
---

<MainLayout>
	<main>
		<article class="movie-hero">
			<img class="backdrop" src={backDropUrl} alt="">
			<div class="movie-content">
				<p class="label paragraaf">Films voor mood: {mood}</p>
				<img class="poster" src={posterUrl} alt="">
				<div class="movie-copy">
					<h1 class="grote-heading">{filmTitel}</h1>
					<p class="paragraaf">{filmBeschrijving}</p>
				</div>
			</div>
		</article>

		<section class="cast-section">
			<h2 class="medium-heading">Cast</h2>
			<ul class="cast-carousel">
					{dataCast.cast.map(function(castMember){
						return (
							<Cast id={castMember.id} imageUrl={castMember.profile_path ? "https://image.tmdb.org/t/p/w500" + castMember.profile_path : "/images/no-img.png"} title={castMember.name} text={"Playing " +castMember.character} transitionName={"cast" + castMember.id} customTransition={customTransition}/>
						)
					})}
			</ul>
		</section>
	</main>
</MainLayout>

<script>
	// @ts-nocheck
	const carousel = document.querySelector(".cast-carousel")
	const cards = document.querySelectorAll(".cast-card")

	function updateCarousel() {
    const carouselCenter = carousel.scrollLeft + carousel.offsetWidth / 2

    cards.forEach(function (card) {
      const cardCenter = card.offsetLeft + card.offsetWidth / 2
      const distance = Math.abs(carouselCenter - cardCenter)

      const maxDistance = carousel.offsetWidth / 2
      const progress = Math.min(distance / maxDistance, 1)

      const scale = 1 - progress * 0.25
      const z = -progress * 180

      card.animate(
        {
          transform: `scale(${scale}) translateZ(${z}px)`
        },
        {
          duration: 300,
          fill: "forwards",
          easing: "ease-out"
        }
      )
    })
  }

  carousel.addEventListener("scroll", updateCarousel)
  window.addEventListener("load", updateCarousel)
	
</script>

<style>
	main {
		display: flex;
		flex-direction: column;
		width: 100%;
		min-height: 100svh;
		background:
			radial-gradient(circle at top right, var(--kleur-primair-container), transparent 100rem),
			linear-gradient(135deg, #11131b 0%, #181b26 48%, #101217 100%);
		color: var(--kleur-op-oppervlak);
		overflow-x: hidden;
	}

	.movie-hero {
		width: 100%;
		min-height: 82svh;
		display: grid;
		grid-template-rows: 1fr;
		position: relative;
		/* de elementen met z index blijven in de element */
		isolation: isolate;

		.backdrop {
			grid-area: 1/1;
			width: 100%;
			height: 100%;
			object-fit: cover;
			opacity: 0.34;
			filter: saturate(0.85);
		}

		&::after {
			content: "";
			grid-area: 1/1;
			background:
				linear-gradient(90deg, rgba(17, 19, 27, 0.94) 0%, rgba(17, 19, 27, 0.78) 42%, rgba(17, 19, 27, 0.3) 100%),
				linear-gradient(0deg, #11131b 0%, rgba(17, 19, 27, 0) 34%);
			z-index: -1;
		}

		.movie-content {
			grid-area: 1/1;
			width: min(72rem, calc(100% - 2rem));
			margin-inline: auto;
			padding-block: 5rem;
			display: grid;
			grid-template-columns: minmax(12rem, 20rem) minmax(0, 1fr);
			grid-template-rows: auto auto;
			align-content: center;
			align-items: end;
			gap: 1.5rem 2rem;
			z-index: 1;
		}

		.label {
			grid-column: 1 / -1;
			width: fit-content;
			padding: 0.45rem 0.8rem;
			border: 1px solid var(--kleur-omlijning-variant);
			border-radius: 999px;
			background-color: var(--kleur-primair-zacht);
			color: var(--kleur-primair);
			font-weight: 600;
		}

		.poster {
			width: 100%;
			border-radius: 8px;
			object-fit: cover;
		}

		.movie-copy {
			display: grid;
			gap: 1rem;
			max-width: 42rem;
			padding-bottom: 0.5rem;
			text-align: left;
		}

		h1 {
			background: var(--verloop-primair);
			background-clip: text;
			color: transparent;
		}

		.movie-copy p {
			color: var(--kleur-op-oppervlak-variant);
			font-size: clamp(1rem, 2vw, 1.15rem);
			line-height: 1.7;
		}
	}

	.cast-section {
		display: grid;
		gap: 1.5rem;
		padding-block: 3rem 5rem;

		> h2 {
			width: min(72rem, calc(100% - 2rem));
			margin-inline: auto;
			color: var(--kleur-op-oppervlak);
		}
	}

	.cast-carousel {
		display: flex;
		flex-direction: row;
		overflow-x: auto;
		overflow-y: visible;
		perspective: 1000px;
		gap: 2rem;
		/* scroll-snap-type: x mandatory; */
		padding: 2rem 40vw 3rem;
		width: 100%;
		height: fit-content;
		list-style: none;
		scrollbar-color: var(--kleur-primair) transparent;


			.cast-card {
				width: clamp(11rem, 20vw, 16rem);
  				flex: 0 0 clamp(11rem, 20vw, 16rem);
				display: grid;
				grid-template-rows: clamp(15rem, 33vh, 22rem) auto auto;
				gap: 0.5rem;
				scroll-snap-align: center;
  				transform-origin: center center;
				padding: 0.75rem;
				border: 1px solid var(--kleur-omlijning-variant);
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.04);
				box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.18);
				
				h2 {
					grid-row: 2;
					height: fit-content;
					color: var(--kleur-op-oppervlak);
					font-family: 'Plus Jakarta Sans', sans-serif;
					font-size: clamp(1rem, 2vw, 1.15rem);
					line-height: 1.2;
				}

				img {
					width: 100%;
  					height: 100%;
					border-radius: 8px;
					grid-area: 1/1;
					object-fit: cover;
					grid-row: 1;
				}

				p {
					grid-row: 3;
					color: var(--kleur-op-oppervlak-variant);
					font-family: 'Inter', sans-serif;
					font-size: 0.9rem;
					line-height: 1.4;
				}
			}

		}

	@media (max-width: 48rem) {
		.movie-hero {
			min-height: auto;

			.movie-content {
				grid-template-columns: 1fr;
				padding-block: 3rem;
			}

			.poster {
				width: min(16rem, 72vw);
			}

			.movie-copy {
				text-align: center;
				justify-items: center;
			}

			.label {
				justify-self: center;
			}
		}

		.cast-carousel {
			padding-inline: 2rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.cast-card {
			transform: none;
		}
	}
</style>
